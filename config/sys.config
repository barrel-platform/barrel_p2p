%% -*- erlang -*-
%%
%% Default sys.config for a mycelium node booted with:
%%
%%   -proto_dist mycelium
%%   -epmd_module mycelium_epmd
%%   -start_epmd false
%%
%% Only the `mycelium' app env is required. `mycelium_dist' projects
%% cert paths, the auth callback, the discovery module, and the
%% listen port into the underlying `quic' app env at listen time.
%% To override any of those, set them explicitly under
%% `{quic, [{dist, [...]}]}'; user-supplied values win over the
%% mycelium defaults.
[
 {mycelium, [
    %% HyParView parameters
    {active_size, 5},
    {passive_size, 30},
    {arwl, 6},
    {prwl, 3},
    {shuffle_length, 8},
    {shuffle_period, 10000},

    %% Distribution port (0 = random)
    {listen_port, 0},

    %% Contact nodes for bootstrap
    {contact_nodes, []},

    %% Churn handling parameters
    {max_fail_count, 5},
    {base_backoff_ms, 1000},
    {passive_max_age_ms, 300000},
    {passive_cleanup_period, 60000},
    {churn_window_ms, 30000},

    %% Ed25519 authentication
    {auth_enabled, true},
    {auth_key_dir, "data/keys"},
    {auth_trust_mode, tofu},
    {auth_handshake_timeout, 10000},
    {auth_timestamp_window, 30000},

    %% QUIC TLS material (auto-generated on first listen).
    {quic_cert_dir, "data/quic"},

    %% Filesystem registry for local auto-discovery. Each booting
    %% node writes <node>.endpoint here; siblings on the same FS
    %% read it back.
    {discovery_dir, "data/discovery"},

    %% Discovery backend chain (first hit wins for lookup; register
    %% fans out to every backend that supports it).
    {discovery_backends,
     [mycelium_discovery_static,
      mycelium_discovery_file,
      mycelium_discovery_dns]}
 ]}
].
