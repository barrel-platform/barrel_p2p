%% -*- erlang -*-
%%
%% Default sys.config for a mycelium node booted with
%% `-proto_dist quic -epmd_module quic_epmd -start_epmd false'.
%%
%%   - `mycelium' env drives the application layer (HyParView, registry,
%%     Ed25519 trust, churn handling).
%%   - `quic' env configures upstream `quic_dist'. Mycelium plugs in via
%%     a composing discovery module (mycelium_discovery) and an auth
%%     callback that runs the Ed25519 challenge between the QUIC
%%     handshake and the dist handshake.
%%
%% NOTE: The kernel boots distribution before sys.config envs apply, so
%% `cert_file' / `key_file' / `port' / `discovery_module' / `auth_callback'
%% must also be passed via `-quic_dist_*' init args. See
%% `examples/chat/scripts/run-demo.sh' for the canonical boot pattern.
%%
%% Cert/key files default to `data/quic/node.{crt,key}'. Run
%% `mycelium_quic_cert:ensure_cert/0' before booting (otherwise
%% `quic_dist:listen/2' fails with `{credentials, no_credentials}').
[
 {mycelium, [
    %% HyParView parameters
    {active_size, 5},
    {passive_size, 30},
    {arwl, 6},
    {prwl, 3},
    {shuffle_length, 8},
    {shuffle_period, 10000},

    %% Distribution port (used by the quic_dist listener)
    {listen_port, 0},  %% 0 = random port

    %% Contact nodes for bootstrap
    {contact_nodes, []},

    %% Churn handling parameters
    {max_fail_count, 5},
    {base_backoff_ms, 1000},
    {passive_max_age_ms, 300000},
    {passive_cleanup_period, 60000},
    {churn_window_ms, 30000},

    %% Ed25519 Authentication (consumed by mycelium_dist_auth_callback)
    {auth_enabled, true},
    {auth_key_dir, "data/keys"},
    {auth_trust_mode, tofu},
    {auth_handshake_timeout, 10000},
    {auth_timestamp_window, 30000},

    %% Default location for the self-signed QUIC TLS cert. Override
    %% with explicit paths in {quic, [{dist, [{cert_file, ...}]}]}.
    {quic_cert_dir, "data/quic"},

    %% Filesystem registry for local auto-discovery. Each booting
    %% node writes <node>.endpoint here; siblings on the same FS
    %% read it back. Override with an absolute path for production.
    {discovery_dir, "data/discovery"},

    %% Discovery backend chain (first hit wins for lookup; register
    %% fans out to every backend that supports it).
    {discovery_backends,
     [mycelium_discovery_static,
      mycelium_discovery_file,
      mycelium_discovery_dns]}
 ]},
 {quic, [
    {dist, [
        %% Identity check between QUIC handshake and Erlang dist handshake.
        {auth_callback, {mycelium_dist_auth_callback, authenticate}},
        {auth_handshake_timeout, 10000},

        %% Composing discovery module (delegates to discovery_backends).
        {discovery_module, mycelium_discovery},

        %% TLS material for the QUIC handshake. Generate via
        %% mycelium_quic_cert:ensure_cert/0 if these don't exist.
        {cert_file, <<"data/quic/node.crt">>},
        {key_file, <<"data/quic/node.key">>}
    ]}
 ]}
].
