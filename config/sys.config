[{mycelium, [
    %% HyParView parameters
    {active_size, 5},
    {passive_size, 30},
    {arwl, 6},
    {prwl, 3},
    {shuffle_length, 8},
    {shuffle_period, 10000},

    %% Distribution port (used by dist carrier)
    {listen_port, 0},  %% 0 = random port

    %% Contact nodes for bootstrap
    {contact_nodes, []},

    %% Churn handling parameters
    {max_fail_count, 5},           %% Max failures before removing from passive view
    {base_backoff_ms, 1000},       %% Base backoff interval (doubles with each failure)
    {passive_max_age_ms, 300000},  %% Max age for passive entries (5 minutes)
    {passive_cleanup_period, 60000}, %% Cleanup period (1 minute)
    {churn_window_ms, 30000},      %% Churn tracking window (30 seconds)

    %% Ed25519 Authentication
    {auth_enabled, true},          %% Enable/disable Ed25519 auth
    {auth_key_dir, "data/keys"},   %% Directory for node keypair and trusted keys
    {auth_trust_mode, tofu},       %% strict = only pre-configured keys, tofu = trust on first use
    {auth_handshake_timeout, 10000}, %% Auth handshake timeout in ms
    {auth_timestamp_window, 30000}   %% Max clock drift allowed in ms
]}].
