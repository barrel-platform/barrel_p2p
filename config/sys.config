%% -*- erlang -*-
%%
%% Default sys.config for a barrel_p2p node booted with:
%%
%%   -proto_dist barrel_p2p
%%   -epmd_module barrel_p2p_epmd
%%   -start_epmd false
%%
%% Only the `barrel_p2p' app env is required. `barrel_p2p_dist' projects
%% cert paths, the auth callback, the discovery module, and the
%% listen port into the underlying `quic' app env at listen time.
%% To override any of those, set them explicitly under
%% `{quic, [{dist, [...]}]}'; user-supplied values win over the
%% barrel_p2p defaults.
[
 {barrel_p2p, [
    %% HyParView parameters
    {active_size, 5},
    {passive_size, 30},
    {arwl, 6},
    {prwl, 3},
    {shuffle_length, 8},
    {shuffle_period, 10000},

    %% Distribution port (0 = random)
    {listen_port, 0},

    %% Contact nodes for bootstrap
    {contact_nodes, []},

    %% Churn handling parameters
    {max_fail_count, 5},
    {base_backoff_ms, 1000},
    {passive_max_age_ms, 300000},
    {passive_cleanup_period, 60000},
    {churn_window_ms, 30000},

    %% Ed25519 authentication
    {auth_enabled, true},
    {auth_key_dir, "data/keys"},
    {auth_trust_mode, tofu},
    {auth_handshake_timeout, 10000},
    {auth_timestamp_window, 30000},

    %% QUIC TLS material (auto-generated on first listen).
    {quic_cert_dir, "data/quic"},

    %% Filesystem registry for local auto-discovery. Each booting
    %% node writes <node>.endpoint here; siblings on the same FS
    %% read it back.
    {discovery_dir, "data/discovery"},

    %% Durable state on disk (WAL + snapshot), recovered on boot so it
    %% survives a full-cluster restart. Per-node paths. Reminders persist
    %% by default; maps persist only with `persist => true'.
    {reminder_data_dir, "data/reminders"},
    {barrel_p2p_map_data_dir, "data/maps"},

    %% Periodic anti-entropy for the value-carrying replica stores (reminder,
    %% map): pull a full sync from a random peer every interval so they
    %% reconverge after a partition heal even without a fresh peer_up. 0
    %% disables; raise it for very large maps.
    {replica_anti_entropy_ms, 30000},

    %% Discovery backend chain (first hit wins for lookup; register
    %% fans out to every backend that supports it).
    {discovery_backends,
     [barrel_p2p_discovery_static,
      barrel_p2p_discovery_file,
      barrel_p2p_discovery_dns]}
 ]}
].
