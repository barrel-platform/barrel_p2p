{erl_opts, [
    debug_info,
    warnings_as_errors
]}.

{deps, []}.

{project_plugins, [rebar3_hex, rebar3_ex_doc]}.

{profiles, [
    {test, [
        {deps, [
            {meck, "0.9.2"},
            {proper, "1.4.0"}
        ]},
        {erl_opts, [nowarn_export_all]}
    ]}
]}.

{dialyzer, [
    {warnings, [
        unknown,
        unmatched_returns,
        error_handling,
        underspecs
    ]},
    {plt_apps, all_deps}
]}.

{xref_checks, [
    undefined_function_calls,
    undefined_functions,
    locals_not_used,
    deprecated_function_calls
]}.

{alias, [
    {check, [xref, dialyzer, eunit, ct]}
]}.

{ct_opts, [{sys_config, ["config/sys.config"]}]}.
