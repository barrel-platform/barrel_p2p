%% Shared config for the docker auth integration cluster. Used by
%% every container so the static discovery backend can resolve
%% sibling node atoms without an upstream EPMD, and so the auth
%% settings stay consistent across the cluster and the test_runner.
%%
%% OTP's `-config' flag does not merge multiple files; the last one
%% wins. We keep one config in this file and override per-container
%% behaviour via `-mycelium <key> <value>' init args from the
%% entrypoint.
[
  {mycelium, [
    {active_size, 5},
    {passive_size, 30},
    {shuffle_period, 5000},
    {max_fail_count, 3},
    {base_backoff_ms, 500},
    {passive_max_age_ms, 60000},
    {churn_window_ms, 10000},

    {auth_enabled, true},
    {auth_key_dir, "/app/data/keys"},
    {auth_trust_mode, tofu},
    {auth_handshake_timeout, 10000},
    {auth_timestamp_window, 30000}
  ]},
  {quic, [
    {dist, [
      %% Absolute cert/key paths. Otherwise CT's per-testcase cwd
      %% change breaks the lookup mid-suite.
      {cert_file, <<"/app/data/quic/node.crt">>},
      {key_file,  <<"/app/data/quic/node.key">>},
      {nodes, [
        {'node1@node1', {"node1", 9101}},
        {'node2@node2', {"node2", 9102}},
        {'node3@node3', {"node3", 9103}}
      ]}
    ]}
  ]}
].
