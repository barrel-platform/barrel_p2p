%% CT configuration for distributed circuit and carrier tests
[
    %% Mycelium configuration with circuit and auth settings
    {mycelium, [
        {active_size, 5},
        {passive_size, 30},
        {shuffle_period, 5000},
        {max_fail_count, 3},
        {base_backoff_ms, 500},
        {passive_max_age_ms, 60000},
        {churn_window_ms, 10000},

        %% Ed25519 Authentication
        {auth_enabled, true},
        {auth_key_dir, "/app/data/keys"},
        {auth_trust_mode, tofu},
        {auth_handshake_timeout, 10000},
        {auth_timestamp_window, 30000},

        %% Encryption
        {encryption_enabled, true},

        %% Circuit settings
        {circuit_establish_timeout, 30000},
        {circuit_ttl, 300000},
        {max_relay_circuits, 500},
        {circuit_reachability_ttl, 60000}
    ]}
].
