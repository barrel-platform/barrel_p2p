%% CT configuration for distributed authentication tests
[
    %% Mycelium configuration with Ed25519 authentication enabled
    {mycelium, [
        {active_size, 5},
        {passive_size, 30},
        {shuffle_period, 5000},
        {max_fail_count, 3},
        {base_backoff_ms, 500},
        {passive_max_age_ms, 60000},
        {churn_window_ms, 10000},

        %% Ed25519 Authentication
        {auth_enabled, true},
        {auth_key_dir, "/app/data/keys"},
        {auth_trust_mode, tofu},
        {auth_handshake_timeout, 10000},
        {auth_timestamp_window, 30000}
    ]}
].
