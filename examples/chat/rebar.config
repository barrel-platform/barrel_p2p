{erl_opts, [debug_info]}.

{deps, [
    %% For local development, mycelium is loaded via _checkouts symlink
    %% For release builds, specify the actual dependency:
    %% {mycelium, {git, "https://github.com/benoitc/mycelium.git", {branch, "main"}}}
]}.

{overrides, [
    {override, mycelium, [{deps, [{hlc, "3.0.2"}]}]}
]}.

{shell, [
    {apps, [chat]}
]}.

{relx, [
    {release, {chat, "0.1.0"}, [
        chat,
        mycelium,
        runtime_tools
    ]},
    {dev_mode, false},
    {include_erts, true},
    {extended_start_script, true},
    {sys_config, "config/sys.config"},
    {vm_args, "config/vm.args"}
]}.

{profiles, [
    {prod, [
        {relx, [
            {dev_mode, false},
            {include_erts, true}
        ]}
    ]}
]}.
