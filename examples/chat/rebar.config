{erl_opts, [debug_info]}.

{deps, [
    %% _checkouts/barrel_p2p symlink overrides this for local development
    {barrel_p2p, {git, "https://github.com/barrel-platform/barrel_p2p.git", {branch, "main"}}}
]}.

{shell, [
    {apps, [chat]},
    {config, "config/sys.config"}
]}.

{relx, [
    {release, {chat, "0.1.0"}, [
        chat,
        barrel_p2p,
        runtime_tools
    ]},
    {dev_mode, false},
    {include_erts, true},
    {extended_start_script, true},
    {sys_config, "config/sys.config"},
    {vm_args, "config/vm.args"}
]}.

{profiles, [
    {prod, [
        {relx, [
            {dev_mode, false},
            {include_erts, true}
        ]}
    ]}
]}.
