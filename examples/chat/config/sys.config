%% -*- erlang -*-
%%
%% sys.config for the chat example. Mirrors the project-root
%% config/sys.config: HyParView envs for the application layer plus
%% the upstream quic_dist hooks (auth callback, HyParView-aware
%% discovery, EPMD registration, TLS material).
[
 {mycelium, [
    {active_size, 3},
    {passive_size, 10},
    {shuffle_period, 5000},
    {listen_port, 9100},
    {contact_nodes, []},

    {auth_enabled, true},
    {auth_key_dir, "data/keys"},
    {auth_trust_mode, tofu},

    {quic_cert_dir, "data/quic"}
 ]},
 {quic, [
    {dist, [
        {auth_callback, {mycelium_dist_auth_callback, authenticate}},
        {auth_handshake_timeout, 10000},
        {discovery_module, mycelium_quic_discovery},
        {register_with_epmd, true},
        {cert_file, <<"data/quic/node.crt">>},
        {key_file,  <<"data/quic/node.key">>}
    ]}
 ]},
 {kernel, [
    {logger_level, info},
    {logger, [
        {handler, default, logger_std_h, #{
            formatter => {logger_formatter, #{
                template => [time, " ", level, " ", msg, "\n"]
            }}
        }}
    ]}
 ]}
].
