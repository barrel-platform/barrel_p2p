%% -*- erlang -*-
%%
%% sys.config for the chat example. Only mycelium envs are needed;
%% mycelium_dist projects the underlying quic_dist wiring at listen
%% time.
[
 {mycelium, [
    {active_size, 3},
    {passive_size, 10},
    {shuffle_period, 5000},
    {listen_port, 9100},
    {contact_nodes, []},
    {dist_cookie, chat},

    {auth_enabled, true},
    {auth_key_dir, "data/keys"},
    {auth_trust_mode, tofu},

    {quic_cert_dir, "data/quic"},
    {discovery_dir, "data/discovery"},
    {discovery_backends,
     [mycelium_discovery_static,
      mycelium_discovery_file,
      mycelium_discovery_dns]}
 ]},
 {kernel, [
    {logger_level, info},
    {logger, [
        {handler, default, logger_std_h, #{
            formatter => {logger_formatter, #{
                template => [time, " ", level, " ", msg, "\n"]
            }}
        }}
    ]}
 ]}
].
