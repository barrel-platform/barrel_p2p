%% -*- erlang -*-
%%
%% sys.config for the chat example. Mirrors the project-root
%% config/sys.config: HyParView envs for the application layer
%% plus the composing discovery module and the auth callback.
%% (cert/key/discovery_module/auth_callback also come through
%% -quic_dist_* init args via run-demo.sh because the kernel
%% boots dist before sys.config envs apply.)
[
 {mycelium, [
    {active_size, 3},
    {passive_size, 10},
    {shuffle_period, 5000},
    {listen_port, 9100},
    {contact_nodes, []},
    {dist_cookie, chat},

    {auth_enabled, true},
    {auth_key_dir, "data/keys"},
    {auth_trust_mode, tofu},

    {quic_cert_dir, "data/quic"},
    {discovery_dir, "data/discovery"},
    {discovery_backends,
     [mycelium_discovery_static,
      mycelium_discovery_file,
      mycelium_discovery_dns]}
 ]},
 {quic, [
    {dist, [
        {auth_callback, {mycelium_dist_auth_callback, authenticate}},
        {auth_handshake_timeout, 10000},
        {discovery_module, mycelium_discovery},
        {cert_file, <<"data/quic/node.crt">>},
        {key_file,  <<"data/quic/node.key">>}
    ]}
 ]},
 {kernel, [
    {logger_level, info},
    {logger, [
        {handler, default, logger_std_h, #{
            formatter => {logger_formatter, #{
                template => [time, " ", level, " ", msg, "\n"]
            }}
        }}
    ]}
 ]}
].
