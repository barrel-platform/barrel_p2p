{erl_opts, [debug_info]}.

{deps, [
    %% For local development against this checkout, a `_checkouts/barrel_p2p'
    %% symlink (scripts/run-local.sh creates one) overrides this git dep.
    {barrel_p2p, {git, "https://github.com/barrel-platform/barrel_p2p.git", {branch, "main"}}}
]}.

{shell, [
    {apps, [quickstart]},
    {config, "config/sys.config"}
]}.

{relx, [
    {release, {quickstart, "0.1.0"}, [
        quickstart,
        barrel_p2p,
        runtime_tools
    ]},
    {dev_mode, false},
    {include_erts, true},
    {extended_start_script, true},
    {sys_config, "config/sys.config"},
    {vm_args, "config/vm.args"}
]}.
