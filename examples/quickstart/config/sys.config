%% -*- erlang -*-
%%
%% sys.config for the quickstart example. Only barrel_p2p envs are needed;
%% barrel_p2p_dist projects the underlying quic_dist wiring at listen time.
%% The per-node key/cert/discovery dirs are left at their defaults here and
%% overridden per node by scripts/run-local.sh for the local two-node demo.
[
 {barrel_p2p, [
    %% HyParView membership
    {active_size, 5},
    {passive_size, 30},

    %% Network: pin the UDP port in production (0 lets the OS choose).
    {listen_port, 9100},

    %% Seeds to auto-join at boot. Empty here: the local demo joins
    %% manually. In production, list two or three stable seeds.
    {contact_nodes, []},

    %% Distribution cookie. barrel_p2p sets this as the node cookie at
    %% boot (overriding -setcookie). Change it for anything real.
    {dist_cookie, quickstart},

    %% Ed25519 peer authentication (on by default).
    {auth_enabled, true},
    {auth_trust_mode, tofu},

    %% Discovery chain: static table, then a shared dir, then DNS.
    {discovery_backends,
     [barrel_p2p_discovery_static,
      barrel_p2p_discovery_file,
      barrel_p2p_discovery_dns]}
 ]},
 {kernel, [
    {logger_level, info}
 ]}
].
